{
  "mcpServers": {
    "apphunter": {
      "command": "node",
      "args": [
        "E:/myapp/MCPServer/AppHunter/dist/index.js"
      ],
      "env": {
        "DB_PATH": "C:/Users/24689/AppData/Roaming/AppHunter/apphunter.db",
        "MCP_READWRITE": "true"
      },
      "disabled": false
    }
  },
  "builtinTools": [
    {
      "name": "calculator",
      "description": "Perform mathematical calculations. Supports basic arithmetic (+, -, *, /), parentheses, decimal numbers, and scientific notation (e.g., 1.5e3). Input is sanitized for security.",
      "parameters": [
        {
          "name": "expression",
          "type": "string",
          "required": true,
          "description": "Mathematical expression to evaluate (e.g., '2 + 3 * 4', 'sin(0.5)', '(1 + 2) * 3')"
        }
      ]
    },
    {
      "name": "get_current_time",
      "description": "Get current date and time in specified timezone. Supports common timezones (UTC, Asia/Shanghai, America/New_York, etc.).",
      "parameters": [
        {
          "name": "timezone",
          "type": "string",
          "required": false,
          "description": "Timezone name (e.g., 'UTC', 'Asia/Shanghai', 'America/New_York'). Default: 'Asia/Shanghai'"
        }
      ]
    },
    {
      "name": "read_file",
      "description": "Read content from a file. Supports both relative paths (relative to sandbox directory) and absolute paths. Maximum file size: 10MB.",
      "parameters": [
        {
          "name": "path",
          "type": "string",
          "required": true,
          "description": "File path to read (relative to sandbox or absolute path)"
        },
        {
          "name": "encoding",
          "type": "string",
          "required": false,
          "description": "File encoding (default: 'utf-8'). Common values: 'utf-8', 'ascii', 'base64'"
        }
      ]
    },
    {
      "name": "write_file",
      "description": "Write content to a file. Creates file if it doesn't exist, overwrites if it does. Supports relative and absolute paths. Maximum file size: 10MB.",
      "parameters": [
        {
          "name": "path",
          "type": "string",
          "required": true,
          "description": "File path to write (relative to sandbox or absolute path)"
        },
        {
          "name": "content",
          "type": "string",
          "required": true,
          "description": "Content to write to the file"
        },
        {
          "name": "encoding",
          "type": "string",
          "required": false,
          "description": "File encoding (default: 'utf-8')"
        }
      ]
    },
    {
      "name": "edit_file",
      "description": "Edit a file using diff format. Applies unified diff to existing file. Useful for making targeted changes without rewriting entire file.",
      "parameters": [
        {
          "name": "path",
          "type": "string",
          "required": true,
          "description": "File path to edit (relative to sandbox or absolute path)"
        },
        {
          "name": "diff",
          "type": "string",
          "required": true,
          "description": "Unified diff format string describing the changes to apply"
        }
      ]
    },
    {
      "name": "list_files",
      "description": "List files and directories in a specified path. Supports recursive listing with depth limit (max 10 levels). Returns file names, types, and sizes.",
      "parameters": [
        {
          "name": "path",
          "type": "string",
          "required": false,
          "description": "Directory path to list (default: current directory). Relative to sandbox or absolute path."
        },
        {
          "name": "recursive",
          "type": "boolean",
          "required": false,
          "description": "Whether to list files recursively (default: false)"
        }
      ]
    },
    {
      "name": "create_directory",
      "description": "Create a new directory. Creates parent directories if they don't exist (like mkdir -p).",
      "parameters": [
        {
          "name": "path",
          "type": "string",
          "required": true,
          "description": "Directory path to create (relative to sandbox or absolute path)"
        }
      ]
    },
    {
      "name": "delete_file",
      "description": "Delete a file or directory. For directories, recursively deletes all contents. Use with caution! Supports safety checks to prevent accidental deletion of critical files.",
      "parameters": [
        {
          "name": "path",
          "type": "string",
          "required": true,
          "description": "File or directory path to delete (relative to sandbox or absolute path)"
        },
        {
          "name": "recursive",
          "type": "boolean",
          "required": false,
          "description": "Whether to recursively delete directories (default: false). Set to true to delete non-empty directories."
        }
      ]
    }
  ],
  "mcpToolDefinitions": {
    "apphunter": [
      {
        "type": "function",
        "function": {
          "name": "apphunter/opportunity_list",
          "description": "列出所有应用市场机会，支持按状态/分类/关键词筛选，返回含综合评分的列表",
          "parameters": {
            "type": "object",
            "properties": {
              "status": {
                "type": "string",
                "description": "状态筛选: pending|evaluating|approved|rejected"
              },
              "category": {
                "type": "string",
                "description": "分类筛选（模糊匹配）"
              },
              "keyword": {
                "type": "string",
                "description": "关键词搜索（名称/备注）"
              },
              "sort": {
                "type": "string",
                "description": "排序方式: created_at|total_score"
              }
            }
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "apphunter/opportunity_get",
          "description": "获取单个机会详情，含评分、评论数、需求数",
          "parameters": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number",
                "description": "机会 ID"
              }
            },
            "required": ["id"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "apphunter/opportunity_create",
          "description": "创建新的应用市场机会（需要读写模式）",
          "parameters": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "应用名称"
              },
              "platform": {
                "type": "string",
                "description": "平台: iOS|Android|Web|Desktop"
              },
              "store_url": {
                "type": "string",
                "description": "应用商店链接"
              },
              "store_rating": {
                "type": "number",
                "description": "商店评分"
              },
              "rating_count": {
                "type": "number",
                "description": "评分数量"
              },
              "pricing_model": {
                "type": "string",
                "description": "定价模式: free|freemium|paid|subscription"
              },
              "price": {
                "type": "number",
                "description": "价格"
              },
              "est_downloads": {
                "type": "string",
                "description": "预估下载量"
              },
              "category": {
                "type": "string",
                "description": "分类"
              },
              "notes": {
                "type": "string",
                "description": "备注"
              }
            },
            "required": ["name", "platform"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "apphunter/opportunity_update",
          "description": "更新机会的字段（需要读写模式）",
          "parameters": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number",
                "description": "机会 ID"
              },
              "name": {
                "type": "string",
                "description": "应用名称"
              },
              "platform": {
                "type": "string",
                "description": "平台"
              },
              "store_url": {
                "type": "string",
                "description": "应用商店链接"
              },
              "store_rating": {
                "type": "number",
                "description": "商店评分"
              },
              "rating_count": {
                "type": "number",
                "description": "评分数量"
              },
              "pricing_model": {
                "type": "string",
                "description": "定价模式"
              },
              "price": {
                "type": "number",
                "description": "价格"
              },
              "est_downloads": {
                "type": "string",
                "description": "预估下载量"
              },
              "category": {
                "type": "string",
