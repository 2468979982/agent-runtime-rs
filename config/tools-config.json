              },
              "status": {
                "type": "string",
                "description": "状态: pending|evaluating|approved|rejected"
              }
            },
            "required": ["id"]
          }
        }
      },
      {
        "type": "function",
        "function": {
          "name": "apphunter/opportunity_score",
          "description": "为机会评分（痛点×3, 付费意愿×3, 难度×2, 竞争×1, 兴趣×1），自动计算综合分（需要读写模式）",
          "parameters": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number",
                "description": "机会 ID"
              },
              "pain_score": {
                "type": "number",
                "description": "痛点评分 (1-5)"
              },
              "willingness_score": {
                "type": "number",
                "description": "付费意愿评分 (1-5)"
              },
              "dev_ease_score": {
                "type": "number",
                "description": "开发难度评分 (1-5, 越高越容易)"
              },
              "competition_score": {
                "type": "number",
                "description": "竞争评分 (1-5, 越高竞争越大)"
              },
              "interest_score": {
                "type": "number",
                "description": "兴趣评分 (1-5)"
              }
            },
            "required": ["id", "pain_score", "willingness_score", "dev_ease_score", "competition_score", "interest_score"]
          }
        }
      },
